  "keyFeatures": [
    "Natural language to shell command translation via Google Gemini or Ollama",
    "Interactive and one-shot execution modes",
    "Safety system with dangerous command detection and dry-run preview",
    "Plugin system for custom command extensions",
    "Smart command history with analytics and bash-style bang commands",
    "Context-aware suggestions for Git, Python, Node.js, and Docker projects",
    "Quick actions: QR codes, hashing, encoding, world clock, calculator",
    "Fuzzy file search, codebase search, and smart grep",
    "Productivity tools: bookmarks, notes, favorites, aliases, templates, workflows",
    "Remote command execution over SSH",
    "AI-powered error recovery with fix suggestions"
  ],
  "publicApiSurface": [
    "prom \"<natural language query>\"",
    "prom (interactive mode)",
    "prom update",
    "prom uninstall",
    "prom info",
    "prom --version",
    "prom config show|edit|reset",
    "prom history [clear|export]",
    "prom --fix",
    "prom --explain",
    "prom --qr \"<text>\"",
    "prom --hash \"<text>\"",
    "prom --time \"<location>\"",
    "plugin list|install|uninstall|create",
    "workflow list|show|run",
    "template list|show|use",
    "remote list|add|remove|exec|test"
